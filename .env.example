REACT_APP_STAGE=local

# Google Maps Platform API key — used by the LocationPicker on the event
# editor and the public event-detail map. Get one at console.cloud.google.com
# and restrict it by HTTP referrer (hypepass.co + localhost:8090).
# Optional in dev: if empty, the picker falls back to manual coord inputs.
REACT_APP_GOOGLE_MAPS_API_KEY=
